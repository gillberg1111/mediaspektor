# MediaSpektor Configuration
servers:
  - type: "plex"
    enabled: true
    url: "http://localhost:32400"
    token: "YOUR_PLEX_TOKEN"
    libraries: ["Movies", "TV Shows"]

  - type: "jellyfin"
    enabled: false
    url: "http://localhost:8096"
    username: "YOUR_JELLYFIN_USERNAME"
    password: "YOUR_JELLYFIN_PASSWORD"
    libraries: ["Movies", "Shows"]   # Jellyfin's default TV library is named "Shows"

  - type: "emby"
    enabled: false
    url: "http://localhost:8096"
    api_key: "YOUR_EMBY_API_KEY"
    user_id: "YOUR_EMBY_USER_ID"          # username or user GUID (resolved at startup)
    libraries: ["Movies", "TV Shows"]     # Emby's default TV library is named "TV Shows"

rules:
  min_age_days: 7
  exclude_labels: ["keep"]
  exclude_genres: ["Documentary"]
  dummy_threshold_mb: 15

aesthetics:
  enable_poster_overlay: true
  banner_color: [8, 11, 10, 204]
  border_color: [62, 207, 142, 255]
  font_name: "Arial"
  font_size_ratio: 0.045

integrations:
  radarr:
    enabled: false
    url: "http://localhost:7878"
    api_key: "YOUR_RADARR_KEY"
  sonarr:
    enabled: false
    url: "http://localhost:8989"
    api_key: "YOUR_SONARR_KEY"
  tmdb:
    # Optional. Enables cross-server ID normalization so the same title is matched
    # across Plex/Jellyfin/Emby even when they store different ID systems
    # (e.g. Plex has only IMDB, Jellyfin only TMDB). Supports a v3 API key or a
    # v4 read-access bearer token. Also readable from the TMDB_API_KEY env var.
    api_key: ""

safety:
  dry_run: true
  backup_original_media: false
  backup_directory: "/path/to/cold/storage/backup"
  allow_automated_archival: false

security:
  enabled: true
  username: "admin"
  password: "admin"
